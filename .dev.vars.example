# Copy to .dev.vars for local development with `npm run dev`.
# Do not commit real secrets.

# Recommended. Used to protect OAuth connection and manual access.
MCP_SHARED_SECRET=

PUBLIC_BASE_URL=http://localhost:8787

# Optional. Fill only if you want Telegram messages.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional. Fill only if you want Discord messages.
DISCORD_WEBHOOK_URL=

# Optional. Fill only if you want Slack messages.
SLACK_WEBHOOK_URL=

# Optional. Fill only if you want a default Make/Zapier/n8n/custom webhook.
DEFAULT_WEBHOOK_URL=

# Optional. Needed only for Worker Builder / child Workers.
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_WORKERS_DEV_SUBDOMAIN=

# Optional examples for saved custom API connectors.
# Add your own uppercase secret names as needed.
# CRM_API_TOKEN=
# BILLING_API_KEY=
# CHILD_WORKER_TOKEN=
